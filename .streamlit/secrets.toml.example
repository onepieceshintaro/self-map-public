# Supabase の Connection Pooling 用 URI（推奨：Session Pooler）
# Supabase ダッシュボード → Connect ボタン → Session pooler → URI
# 形式：
#   postgresql://postgres.<project-ref>:<password>@<host>:5432/postgres
# もしくは：
#   postgres://...
# どちらでも db.py 側で自動変換される。
#
# このファイルをコピーして secrets.toml を作り、実際の値を入れる。
# secrets.toml は .gitignore で除外されているので GitHub には上がらない。
DATABASE_URL = "postgresql://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"
